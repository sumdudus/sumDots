{
	"layer": "top",
	"position": "top",
	"margin-bottom": -3,
	"spacing": 8,
	"mode": "top",
	"height": 25,
	"expand-left": true,
	"expand-center": true,
	"expand-right": true,
	"reload_stlye_on_change": true,
	"modules-left": ["group/hardware","group/networks","custom/blankL"],
	"modules-center": ["hyprland/workspaces"],
	"modules-right": ["custom/blankR","group/BatLanVol","custom/clock","group/time"],

	"clock#simpleclock": {
	   "format": " {:%a, %b %d}",
	//    "format-alt": "",
	   "interval": 1,
	   "tooltip": false,
        },

	"tray": {
	   "show-passive-items": true,
	   "icon-size": 17,
	   "spacing": 0
	},

	"clock#clock": {
	   "tooltip": false,
	   "format": "{:%H:%M}",
	},

	"custom/tailscale": {
	   "format": "{}",
	   "return-type":"json",
	   "on-click": "$HOME/.config/waybar/tailscale/tailscaletoggle.sh",
	   "restart-interval": 0,
	   "exec": "$HOME/.config/waybar/tailscale/tailscale.sh status",
	},

	"group/networks": {
	   "orientation": "inherit",
	   "drawer": {
		"transition-duration": 500,
		"click-to-reveal": true,
		"transition-left-to-right": true,
	   },
	"modules": [
	   "custom/network-wrap",
	   "custom/tailscale",
	   "network",
	   ]
	},

	"custom/network-wrap": {
	   "format": "",
	   "tooltip": false,
	},

	"group/time": {
	   "orientation": "inherit",
	   "drawer": {
		"transition-duration": 500,
		"click-to-reveal": true,
		"transition-left-to-right":false
		},
	   "modules": [
		"clock#clock",
		"clock#simpleclock"
		]
	},

	"pulseaudio": {
	   "format": "{volume}% {icon}",
	   "format-icons": {
		"default": ["", "", ""]
		},
	//    "format-alt": "{icon}"
	},

	"hyprland/language": {
	   "format": "{}",
	   "format-en": "en",
	   "format-ru": "ru"
	},

	"battery": {
	   "format": "{capacity}% {icon}",
	   "format-icons": ["", "", "", "", ""],
	//    "format-alt": "{icon}",
	   "format-charging": " {capacity}%",
	},

	"network": {
	   "interface": ["enp2s0", "wlan0"],
	   "tooltip": false,
	   "format-wifi": "⇣{bandwidthDownBytes} ⇡{bandwidthUpBytes} ",
	   "format-ethernet": "⇣{bandwidthDownBytes} ⇡{bandwidthUpBytes} ",
	   "interval": 1
	},

	"group/BatLanVol": {
	   "orientation": "inherit",
	   "drawer": {
		"transition-duration": 500,
		"click-to-reveal": true,
		"transition-left-to-right":false
		},
	   "modules": [
		"hyprland/language",
		"battery",
		"pulseaudio"
	   ]
	},

	"cpu": {
	   "format": " {usage}%",
	   "interval": 1,
	//    "format-alt": " "
	},

	"memory": {
	   "format": "󰘚  {used}GiB",
	   "interval": 1,
	//    "format-alt":"󰘚 "
	},

	"temperature": {
	   "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon/hwmon6",
	   "input-filename": "temp1_input",
	   "format": "{temperatureC}°C ",
	   "interval": 1
	},

	"custom/hardware-wrap": {
	   "format": "󰭍",
	   "tooltip": false,
	},

	"group/hardware": {
	   "orientation": "inherit",
	   "drawer": {
		"transition-duration": 500,
		"transition-left-to-right": true,
		"click-to-reveal": true
	   },
	   "modules": [
		"custom/hardware-wrap",
		"cpu",
		"memory",
		"temperature"
	   ]
	},

	"custom/blankL": {
	   "format": " ",
	   "expand": true,
	   "tooltip": false
	},

	"custom/blankR": {
	   "format": " ",
	   "expand": true,
	   "tooltip": false
	},

	"custom/blankM": {
	   "format": " ",
	   "expand": true
	},

	"hyprland/workspaces": {
	   "persistent-workspaces": {
		"1":[],
		"2":[],
		"3":[],
		"4":[],
	   },
	   "format":"{icon}",
	   "format-icons": {
		"active":"",
		"default":""
	 },
	}
}
